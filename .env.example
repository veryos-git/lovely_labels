# Lovely Labels — runtime configuration.
#
#   cp .env.example .env   # then tweak the values below
#
# This gitignored .env is loaded automatically by:
#   - the local `deno task serve|start|build-tiles|run` commands (--env-file)
#   - `docker compose up` (Compose interpolates ${...} from ./.env, with the
#     defaults in docker-compose.yml as fallback)
# It is NOT read by Render: the cloud has no access to a gitignored local file,
# so production config lives in render.yaml (envVars) / the Render dashboard.

# Port the Deno server listens on. Render injects its own value at runtime.
PORT=8080

# Path or name of the ImageMagick binary used for server-rendered text and
# tile resizing. Inside the Docker image this is symlinked from
# /usr/bin/convert (ImageMagick 6 on Debian).
MAGICK_BIN=magick
