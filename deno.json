{
  "tasks": {
    "install": "cd client && npm install",
    "dev": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "build-tiles": "deno run --allow-read --allow-write --allow-run=magick scripts/build_tiles.ts",
    "serve": "deno run --allow-net --allow-read --allow-env server.ts",
    "start": "deno task build && deno task serve"
  },
  "fmt": {
    "include": ["server.ts"]
  }
}
